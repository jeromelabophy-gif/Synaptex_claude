# Synaptex configuration — copy to ~/.synaptex/.env and fill in your values
# chmod 600 ~/.synaptex/.env

# Git provider (forgejo | gitea | github | gitlab | local)
FORGE_TYPE=local

# API credentials — not required for FORGE_TYPE=local
# FORGE_URL=http://your-forgejo-host:3000
# FORGE_TOKEN=your-read-only-token-here
# FORGE_USER=your-username

# Local scan — used when FORGE_TYPE=local
# Accepts multiple paths separated by ":" (e.g. ~/projects:~/ObsidianVault)
LOCAL_REPOS_PATH=~/projects

# Files to index per repo (comma-separated globs)
SYNAPTEX_INCLUDE_PATTERNS=CLAUDE.md,README.md,MEMORY.md

# Search backend (embed | leann | fts5)
SYNAPTEX_SEARCH_BACKEND=embed

# Ollama or OpenAI-compatible embedding provider
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_TYPE=ollama
OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_FALLBACK_MODEL=mxbai-embed-large
# OLLAMA_API_KEY=sk-your-key-here   # only for OpenAI-compatible APIs
